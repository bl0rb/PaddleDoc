# PaddleDock runtime tuning (docker compose)
# Copy to .env and adjust for your host.

# Worker container resource limits
WORKER_MEMORY_LIMIT=3g
WORKER_CPUS=2.0

# Celery worker tuning
CELERY_WORKER_CONCURRENCY=1
CELERY_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=20
CELERY_LOG_LEVEL=info

# ONNX / OpenMP memory+CPU tuning (especially helpful on small ARM hosts)
OMP_NUM_THREADS=1
ONNXRUNTIME_INTRA_OP_NUM_THREADS=1
ONNXRUNTIME_INTER_OP_NUM_THREADS=1
MALLOC_ARENA_MAX=2
